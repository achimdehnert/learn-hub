# learn-hub .env.prod template
# Copy to .env.prod and fill in values

DJANGO_SECRET_KEY=change-me-to-a-strong-random-string
DEBUG=False
ALLOWED_HOSTS=learn.iil.pet,localhost

DATABASE_NAME=learn_hub
